# ─────────────────────────────────────────────
#  Dayton Relo App — Environment Variables
#  Copy this file to .env and fill in values.
#  All vars must be prefixed EXPO_PUBLIC_ to be
#  accessible in client-side Expo code.
# ─────────────────────────────────────────────

# ── SimplyRETS IDX Feed ───────────────────────
# Get credentials at https://simplyrets.com
EXPO_PUBLIC_SIMPLYRETS_USER=simplyrets
EXPO_PUBLIC_SIMPLYRETS_PASSWORD=simplyrets

# ── CRM Webhook (Zapier compatible) ───────────
# Paste your Zapier Webhook URL or any POST endpoint
EXPO_PUBLIC_CRM_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/YOUR_HOOK_ID/

# ── Twilio SMS (agent lead notifications) ─────
# https://console.twilio.com
EXPO_PUBLIC_TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_TWILIO_AUTH_TOKEN=your_auth_token
EXPO_PUBLIC_TWILIO_FROM_NUMBER=+19375550100
# The agent's cell — receives a text for every lead
EXPO_PUBLIC_AGENT_PHONE=+19375550199

# ── Claude AI (DaytonBot chat) ────────────────
# Get your key at https://console.anthropic.com
EXPO_PUBLIC_CLAUDE_API_KEY=sk-ant-api03-...

# ── FRED API (live mortgage rates widget) ──────
# Free registration at https://fred.stlouisfed.org/docs/api/api_key.html
# Powers the 30yr / 15yr / VA rate widget. Falls back to estimates if blank.
EXPO_PUBLIC_FRED_API_KEY=
